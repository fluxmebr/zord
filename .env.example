# ============================================================
# ZORD — Environment Variables (copy to .env)
# ============================================================

# App
NODE_ENV=development
APP_URL=https://zord.pro
API_URL=https://api.zord.pro

# PostgreSQL
DATABASE_URL=postgresql://zord:zord_secret@localhost:5432/zord_db
DATABASE_SHADOW_URL=postgresql://zord:zord_secret@localhost:5432/zord_shadow

# Redis
REDIS_URL=redis://localhost:6379

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=zord_neo4j_secret

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=zord_opensearch_secret

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=zord_minio_access
MINIO_SECRET_KEY=zord_minio_secret
MINIO_BUCKET_EVIDENCE=zord-evidence

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRES_IN=7d

# AI
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Email (para MFA e notificações)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@zord.pro

# Encriptação AES-256
ENCRYPTION_KEY=change_this_32_char_key_in_prod!!
